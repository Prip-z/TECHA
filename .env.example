APP_NAME=HackBack Backend
APP_ENV=local
DEBUG=false
LOG_LEVEL=INFO
AUTH_SECRET=change-me-before-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://0.0.0.0:8000
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$

PG_HOST=localhost
PG_PORT=5432
PG_DB=hackback
PG_USER=hackback
PG_PASS=hackback

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

BACKEND_EXTERNAL_PORT=8000
DB_EXTERNAL_PORT=5432
